DATABASE_URL="mysql://USERNAME:PASSWORD@localhost:3306/mfn_hr"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
# Microsoft Entra ID web app settings for Auth.js.
# Redirect URI to register in Entra:
#   Local:      http://localhost:3000/api/auth/callback/microsoft-entra-id
#   Production: https://your-app.example.com/api/auth/callback/microsoft-entra-id
#
# AUTH_MICROSOFT_ENTRA_ID_ID must be the Application (client) ID GUID from the
# Entra app registration. Do not use the api://... Application ID URI here.
AUTH_MICROSOFT_ENTRA_ID_ID="00000000-0000-0000-0000-000000000000"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-microsoft-entra-app-client-secret"
# Issuer should be tenant-specific, for example:
# https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
# This app expects an internal single-tenant Entra setup and validates the
# tid claim against the tenant ID embedded in this issuer URL.
# Microsoft sign-in is also restricted in code to @mfncuso.com accounts only.
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0"
# Temporary / break-glass only. Set to "false" in deployed environments once
# Microsoft 365 sign-in is verified.
AUTH_ENABLE_DEV_AUTH="false"
AUTH_DEV_PASSWORD="change-me-for-local-dev"
AUTH_DEV_AUTH_EMAIL_ALLOWLIST="employee1@example.com,employee2@example.com"
# Development-only. Keep this "false" outside local development.
AUTH_ENABLE_DEV_USER_SWITCHER="false"
# Email delivery:
# - Local/dev safe testing: EMAIL_TRANSPORT="dev"
# - Production Microsoft Graph app-only: EMAIL_TRANSPORT="graph"
EMAIL_TRANSPORT="dev"
EMAIL_FROM="hr@managedfinancialnetworks.com"
EMAIL_REPLY_TO="hr@managedfinancialnetworks.com"
APP_BASE_URL="http://localhost:3000"
# Microsoft Graph app-only mail settings.
# GRAPH_MAILBOX_USER_ID should be the mailbox user principal name or object ID
# the app is allowed to send as via POST /users/{mailbox}/sendMail and the
# same mailbox default calendar is used for approved PTO events.
GRAPH_TENANT_ID="00000000-0000-0000-0000-000000000000"
GRAPH_CLIENT_ID="00000000-0000-0000-0000-000000000000"
GRAPH_CLIENT_SECRET="replace-with-your-graph-client-secret"
GRAPH_MAILBOX_USER_ID="hr@managedfinancialnetworks.com"
DOCUMENT_STORAGE_ROOT=/var/lib/mfn-hr-documents