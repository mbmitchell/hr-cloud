#
# HR Cloud fork example environment
# Use dedicated infrastructure and secrets for this fork.
# Do not reuse MFN production database names, app URLs, mailbox identities,
# document storage roots, or internal job secrets.
#
DATABASE_URL="postgresql://HR_CLOUD_DB_USER:HR_CLOUD_DB_PASSWORD@localhost:5432/hr_cloud?schema=public"
NEXTAUTH_SECRET="GENERATE_A_UNIQUE_HR_CLOUD_SECRET"
NEXTAUTH_URL="http://localhost:3000"
# Microsoft Entra ID web app settings for Auth.js.
# Redirect URI to register in Entra:
#   Local:      http://localhost:3000/api/auth/callback/microsoft-entra-id
#   Production: https://hr-cloud.example.com/api/auth/callback/microsoft-entra-id
#
# AUTH_MICROSOFT_ENTRA_ID_ID must be the Application (client) ID GUID from the
# Entra app registration. Do not use the api://... Application ID URI here.
AUTH_MICROSOFT_ENTRA_ID_ID="HR_CLOUD_ENTRA_APP_CLIENT_ID_GUID"
AUTH_MICROSOFT_ENTRA_ID_SECRET="HR_CLOUD_ENTRA_APP_CLIENT_SECRET"
# Issuer should be tenant-specific, for example:
# https://login.microsoftonline.com/HR_CLOUD_TENANT_ID/v2.0
# This app expects an internal single-tenant Entra setup and validates the
# tid claim against the tenant ID embedded in this issuer URL.
# Current runtime behavior note:
# Microsoft sign-in is still restricted in code to @mfncuso.com accounts until
# a later auth-specific change is made. These values are placeholders only.
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/HR_CLOUD_TENANT_ID/v2.0"
# Temporary / break-glass only. Set to "false" in deployed environments once
# Microsoft 365 sign-in is verified. This must remain "false" in production.
AUTH_ENABLE_DEV_AUTH="false"
AUTH_DEV_PASSWORD="change-me-for-local-dev"
AUTH_DEV_AUTH_EMAIL_ALLOWLIST="employee1@hr-cloud.example.com,employee2@hr-cloud.example.com"
# Development-only. Keep this "false" outside local development.
AUTH_ENABLE_DEV_USER_SWITCHER="false"
# Email delivery:
# - Local/dev safe testing: EMAIL_TRANSPORT="dev"
# - Production Microsoft Graph app-only: EMAIL_TRANSPORT="graph"
EMAIL_TRANSPORT="dev"
EMAIL_FROM="notifications@hr-cloud.example.com"
EMAIL_REPLY_TO="hr@hr-cloud.example.com"
APP_BASE_URL="http://localhost:3000"
# Microsoft Graph app-only mail settings.
# GRAPH_MAILBOX_USER_ID should be the mailbox user principal name or object ID
# the app is allowed to send as via POST /users/{mailbox}/sendMail and the
# same mailbox default calendar is used for approved PTO events.
GRAPH_TENANT_ID="HR_CLOUD_GRAPH_TENANT_ID"
GRAPH_CLIENT_ID="HR_CLOUD_GRAPH_CLIENT_ID"
GRAPH_CLIENT_SECRET="HR_CLOUD_GRAPH_CLIENT_SECRET"
GRAPH_MAILBOX_USER_ID="notifications@hr-cloud.example.com"
DOCUMENT_STORAGE_ROOT=/var/lib/hr-cloud-documents
DOCUMENT_ACKNOWLEDGEMENT_REMINDERS_ENABLED="true"
DOCUMENT_ACKNOWLEDGEMENT_REMINDER_STALE_DAYS="7"
HR_NOTIFICATION_BATCH_SIZE="25"
HR_NOTIFICATION_MAX_ATTEMPTS="5"
HR_NOTIFICATION_RETRY_DELAY_MINUTES="30"
INTERNAL_JOB_SECRET="GENERATE_A_UNIQUE_HR_CLOUD_INTERNAL_JOB_SECRET"
JOB_CHANGE_AUTO_APPLY_ENABLED="true"
JOB_CHANGE_PENDING_ESCALATION_DAYS="3"
PTO_PENDING_ESCALATION_HOURS="48"
